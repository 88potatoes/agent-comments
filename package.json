{
  "name": "@88potatoes/agent-comments",
  "version": "1.0.1",
  "description": "Inline comment system for code reviews — CLI + nvim plugin",
  "keywords": [
    "code-review",
    "comments",
    "cli"
  ],
  "license": "ISC",
  "author": "",
  "type": "module",
  "bin": {
    "agent-comments": "dist/agent-comments.mjs",
    "aco": "dist/agent-comments.mjs"
  },
  "files": [
    "dist/",
    "drizzle/",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --jsx=automatic --external:better-sqlite3 --external:ink --external:react --external:@tanstack/react-query --external:drizzle-orm --outfile=dist/agent-comments.mjs --banner:js='#!/usr/bin/env node'",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --jsx=automatic --external:better-sqlite3 --external:ink --external:react --external:@tanstack/react-query --external:drizzle-orm --outfile=dist/agent-comments.mjs --banner:js='#!/usr/bin/env node' --watch",
    "dev:debug": "AGENT_COMMENTS_DEBUG=1 node --watch-path=./dist ./dist/agent-comments.mjs tui",
    "dev:log": "tail -f tmp/ac-debug.log",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepublishOnly": "pnpm build && pnpm test",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "better-sqlite3": "^11.0.0",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.5.0",
    "ink": "^7.1.1",
    "react": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
